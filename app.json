{
  "expo": {
    "name": "Yarn Tracker",
    "slug": "yarn-tracker",
    "scheme": "yarn-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/iconapp-padded.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.deltagalil.yarntracker",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/iconapp.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/iconapp.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/iconapp-padded.png",
      "name": "Yarn Tracker",
      "shortName": "YarnTracker",
      "description": "Yarn inventory tracking application",
      "backgroundColor": "#ffffff",
      "themeColor": "#2196F3",
      "display": "standalone",
      "orientation": "portrait",
      "scope": "/",
      "startUrl": "/"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9c85346a-9909-4e96-a58b-41f021666904"
      }
    },
    "owner": "myth12"
  }
}
